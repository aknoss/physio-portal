{
  "name": "@physio-portal/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "echo 'api dev server lands in Stage 1'",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "tsx src/db/migrate-cli.ts up",
    "db:migrate:down": "tsx src/db/migrate-cli.ts down",
    "db:migrate:status": "tsx src/db/migrate-cli.ts status"
  },
  "dependencies": {
    "@physio-portal/contracts": "*",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.28.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^2.1.8",
    "testcontainers": "^10.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
